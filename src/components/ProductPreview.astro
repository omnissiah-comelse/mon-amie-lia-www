---
import { childPreview, weeklySummaryPreview } from '../data/site';
---

<!-- Child preview: conversation -->
<div class="grid gap-10 lg:grid-cols-2">
  <!-- Left: Chat preview -->
  <div class="rounded-[2rem] border border-border bg-surface p-6 shadow-sm">
    <div class="mb-4 flex items-center justify-between">
      <h3 class="font-display text-lg font-bold text-foreground">Vue enfant</h3>
      <div class="flex gap-2">
        {childPreview.tabs.map((tab) => (
          <span
            class={`rounded-full px-3 py-1 text-xs font-semibold ${
              tab === childPreview.activeTab
                ? 'bg-primary text-primary-foreground'
                : 'bg-surface-muted text-muted'
            }`}
          >
            {tab}
          </span>
        ))}
      </div>
    </div>

    <div class="space-y-3">
      {childPreview.messages.map((msg) => (
        <div class={`flex ${msg.role === 'child' ? 'justify-end' : 'justify-start'}`}>
          <div
            class={`max-w-[80%] rounded-2xl px-4 py-2.5 text-sm leading-relaxed ${
              msg.role === 'child'
                ? 'bg-primary/10 text-foreground'
                : 'bg-surface-muted text-foreground'
            }`}
          >
            {msg.role === 'lia' && (
              <span class="text-xs font-bold text-primary block mb-1">Lia</span>
            )}
            {msg.text}
          </div>
        </div>
      ))}
    </div>

    <div class="mt-6 border-t border-border pt-4">
      <p class="text-xs font-bold uppercase tracking-widest text-muted mb-2">Notes pédagogiques</p>
      <ul class="space-y-1.5">
        {childPreview.coachNotes.map((note) => (
          <li class="flex items-start gap-2 text-xs text-muted">
            <svg class="mt-0.5 h-3.5 w-3.5 shrink-0 text-accent-foreground" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
            {note}
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Right: Parent weekly summary -->
  <div class="rounded-[2rem] border border-border bg-surface p-6 shadow-sm">
    <div class="mb-4 flex items-center justify-between">
      <h3 class="font-display text-lg font-bold text-foreground">Vue parent — résumé hebdo</h3>
      <span class="inline-flex items-center gap-1.5 rounded-full bg-accent px-3 py-1 text-xs font-semibold text-accent-foreground">
        {weeklySummaryPreview.status}
      </span>
    </div>

    <p class="text-sm text-muted mb-4">{weeklySummaryPreview.weekLabel}</p>

    <!-- Metrics -->
    <div class="grid grid-cols-3 gap-3 mb-6">
      {weeklySummaryPreview.metrics.map((m) => (
        <div class="rounded-xl bg-surface-muted p-3 text-center">
          <div class="font-display text-2xl font-bold text-foreground">{m.value}</div>
          <div class="text-xs text-muted mt-0.5">{m.label}</div>
        </div>
      ))}
    </div>

    <!-- Subjects -->
    <div class="space-y-4 mb-6">
      {weeklySummaryPreview.subjects.map((s) => (
        <div>
          <div class="flex items-center justify-between mb-1">
            <span class="text-sm font-semibold text-foreground">{s.subject}</span>
            <span class="text-xs font-bold text-primary">{s.progress}%</span>
          </div>
          <div class="h-2 rounded-full bg-surface-muted overflow-hidden">
            <div class="h-full rounded-full bg-primary/70" style={`width: ${s.progress}%`}></div>
          </div>
          <p class="text-xs text-muted mt-1">{s.note}</p>
        </div>
      ))}
    </div>

    <!-- Notes -->
    <div class="mb-4">
      <p class="text-xs font-bold uppercase tracking-widest text-muted mb-2">Observations</p>
      <ul class="space-y-1.5">
        {weeklySummaryPreview.notes.map((note) => (
          <li class="flex items-start gap-2 text-xs text-muted">
            <span class="mt-1 h-1.5 w-1.5 shrink-0 rounded-full bg-muted/40"></span>
            {note}
          </li>
        ))}
      </ul>
    </div>

    <!-- Follow-up -->
    <div class="rounded-xl bg-accent/30 p-3">
      <p class="text-xs font-bold uppercase tracking-widest text-accent-foreground mb-2">Suggestions pour la semaine</p>
      <ul class="space-y-1">
        {weeklySummaryPreview.followUp.map((f) => (
          <li class="flex items-start gap-2 text-xs text-accent-foreground">
            <svg class="mt-0.5 h-3.5 w-3.5 shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            {f}
          </li>
        ))}
      </ul>
    </div>
  </div>
</div>
