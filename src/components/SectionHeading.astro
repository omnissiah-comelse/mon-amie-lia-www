---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<div class="mx-auto max-w-2xl text-center mb-12">
  {eyebrow && (
    <p class="text-xs font-bold uppercase tracking-widest text-primary mb-3">{eyebrow}</p>
  )}
  <h2 class="font-display text-3xl font-bold tracking-tight text-foreground sm:text-4xl">{title}</h2>
  {description && (
    <p class="mt-4 text-base text-muted leading-relaxed">{description}</p>
  )}
</div>
