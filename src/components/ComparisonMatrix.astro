---
import { comparisonColumns, comparisonRows } from '../data/site';
import type { ComparisonTone } from '../data/site';

function toneClasses(tone: ComparisonTone): string {
  switch (tone) {
    case 'best':
      return 'bg-accent/60 border-accent-foreground/20';
    case 'good':
      return 'bg-surface-muted border-border';
    case 'mixed':
      return 'bg-amber-50/60 border-amber-200/40';
    case 'limited':
      return 'bg-red-50/40 border-red-200/40';
    default:
      return 'bg-surface-muted border-border';
  }
}

function toneDot(tone: ComparisonTone): string {
  switch (tone) {
    case 'best':
      return 'bg-accent-foreground';
    case 'good':
      return 'bg-primary';
    case 'mixed':
      return 'bg-warning';
    case 'limited':
      return 'bg-red-400';
    default:
      return 'bg-muted';
  }
}
---

<div class="overflow-x-auto">
  <table class="w-full min-w-[800px] border-collapse text-sm">
    <thead>
      <tr>
        <th class="p-3 text-left font-medium text-muted w-[180px]"></th>
        {comparisonColumns.map((col) => (
          <th class={`p-3 text-left ${col.highlight ? 'bg-accent/30 rounded-t-2xl' : ''}`}>
            <div class="font-display font-bold text-foreground">{col.name}</div>
            <div class="text-xs font-normal text-muted mt-0.5">{col.caption}</div>
          </th>
        ))}
      </tr>
    </thead>
    <tbody>
      {comparisonRows.map((row, ri) => (
        <tr class={ri % 2 === 0 ? 'bg-surface-muted/40' : ''}>
          <td class="p-3 font-medium text-foreground align-top">{row.feature}</td>
          {row.values.map((val, vi) => (
            <td class={`p-3 align-top ${comparisonColumns[vi].highlight ? 'bg-accent/10' : ''}`}>
              <div class={`rounded-xl border p-3 ${toneClasses(val.tone as ComparisonTone)}`}>
                <div class="flex items-center gap-1.5 mb-1">
                  <span class={`inline-block h-2 w-2 rounded-full ${toneDot(val.tone as ComparisonTone)}`}></span>
                  <span class="font-semibold text-foreground text-xs">{val.title}</span>
                </div>
                <p class="text-xs text-muted leading-relaxed">{val.description}</p>
              </div>
            </td>
          ))}
        </tr>
      ))}
    </tbody>
  </table>
</div>
